# Tailscale auth key for DNS container
# Generate at: https://login.tailscale.com/admin/settings/keys
# Requirements: tag:dns must be defined in ACL tagOwners
# Recommended: reusable=off, ephemeral=off
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX
TS_AUTH_ONCE=true
TS_STATE_DIR=/var/lib/tailscale
TS_USERSPACE=false
TS_EXTRA_ARGS=--advertise-tags=tag:dns --accept-dns=false

# Tailscale MagicDNS domain (find with: tailscale status --json | grep MagicDNSSuffix)
TS_MAGIC_DOMAIN=tail6629d6.ts.net

# Path to arcane device root (must match parent .env)
ARCANE=/home/vlgoncalves/arcane/asmodeus
