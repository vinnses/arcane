# === Arcane ===
ARCANE=/home/vlgoncalves/arcane/asmodeus

# === Repository ===
# Absolute path where Kopia stores the backup repository on the host
KOPIA_REPO_PATH=/home/vlgoncalves/path/to/kopia-repo

# Repository encryption password
KOPIA_PASSWORD=changeme_repository_password

# === Web UI ===
KOPIA_SERVER_USERNAME=admin
KOPIA_SERVER_PASSWORD=changeme_server_password
KOPIA_PORT=51515

# === Kopia internal paths (do not change) ===
KOPIA_CACHE_DIRECTORY=/app/cache
KOPIA_LOG_DIR=/app/logs

# === Source paths ===
# Absolute host paths for each backup source
VAULT_PATH=/home/vlgoncalves/path/to/vault
# IMMICH_UPLOAD_PATH=/home/vlgoncalves/path/to/immich/upload
