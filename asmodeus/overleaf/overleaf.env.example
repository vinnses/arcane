# --- App ---
OVERLEAF_APP_NAME=Overleaf
OVERLEAF_SITE_URL=http://latex.asmodeus.hell

# --- Services ---
OVERLEAF_MONGO_URL=mongodb://mongo/sharelatex?replicaSet=overleaf
OVERLEAF_REDIS_HOST=redis
REDIS_HOST=redis
REDIS_PORT=6379

# --- Auth ---
EMAIL_CONFIRMATION_DISABLED=true
EXTERNAL_AUTH=none

# --- Features ---
ENABLE_CONVERSIONS=true
ENABLED_LINKED_FILE_TYPES=project_file,project_output_file

# --- TexLive ---
# texlive installation is manual, inside the running sharelatex container:
# docker compose exec sharelatex /opt/arcane/scripts/texlive-install.sh
# Optional: manual mirror override when executing the script
# TEXLIVE_MIRROR=https://ftp.math.utah.edu/pub/tex/historic/systems/texlive/2025/tlnet-final
