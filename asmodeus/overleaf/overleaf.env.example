# --- App ---
OVERLEAF_APP_NAME=Overleaf
OVERLEAF_SITE_URL=http://latex.asmodeus.hell

# --- Services ---
OVERLEAF_MONGO_URL=mongodb://mongo/sharelatex?replicaSet=overleaf
OVERLEAF_REDIS_HOST=redis
REDIS_HOST=redis
REDIS_PORT=6379

# --- Auth ---
EMAIL_CONFIRMATION_DISABLED=true
EXTERNAL_AUTH=none

# --- Features ---
ENABLE_CONVERSIONS=true
ENABLED_LINKED_FILE_TYPES=project_file,project_output_file

# --- TexLive ---
# Set to true to install texlive-full on first boot (blocks until complete, ~30-60min)
TEXLIVE_FULL=false
# Optional: override CTAN mirror (skip auto-detection)
# TEXLIVE_MIRROR=https://ctan.dcc.uchile.cl/systems/texlive/tlnet
