# Arcane device root (must match lilith/.env)
ARCANE=/home/vlgoncalves/arcane/lilith

# ── Container identity (change freely) ────────────────────────────────────────
VIBE_USER=vibecoder
VIBE_CONTAINER=vibe
VIBE_HOSTNAME=vibe

# ── Host user IDs ─────────────────────────────────────────────────────────────
PUID=1000
PGID=1000

# ── Paths ─────────────────────────────────────────────────────────────────────
# Host directory for projects (mounted at ~/projects)
VIBE_CODE_PATH=/home/vlgoncalves/Projects

# ── SSH ───────────────────────────────────────────────────────────────────────
VIBE_SSH_PORT=2222
