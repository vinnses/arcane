# Arcane device root (must match lilith/.env)
ARCANE=/home/vlgoncalves/arcane/lilith

# ── Device ───────────────────────────────────────────────────────────────────
# Hostname prefix for Tailscale (becomes ${DEVICE}-viber on the tailnet)
DEVICE=lilith

# ── Container user ────────────────────────────────────────────────────────────
VIBE_USER=vibecoder
PUID=1000
PGID=1000

# ── Paths ─────────────────────────────────────────────────────────────────────
# Host directory for projects
PROJECT_PATH=/home/vlgoncalves/vibeproject

# ── Tailscale ────────────────────────────────────────────────────────────────
# Generate at: https://login.tailscale.com/admin/settings/keys
# Requirements: tag:viber must be defined in ACL tagOwners
# Recommended: reusable=off, ephemeral=off
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX
TS_AUTH_ONCE=true
TS_STATE_DIR=/var/lib/tailscale
TS_USERSPACE=false
TS_EXTRA_ARGS=--advertise-tags=tag:viber
